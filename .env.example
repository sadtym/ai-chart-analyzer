# ═══════════════════════════════════════════════════════════════
# 📋 فایل تنظیمات محیطی (Environment Variables)
# ═══════════════════════════════════════════════════════════════
# این فایل را کپی کرده و به .env تغییر نام دهید
# ═══════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════
# 🎯 انتخاب هوش مصنوعی
# ═══════════════════════════════════════════════════════════════
# برای استفاده رایگان: gemini
# برای دقت بالاتر (هزینه‌بر): openai
AI_PROVIDER=gemini

# ═══════════════════════════════════════════════════════════════
# 💬 توکن ربات تلگرام (اجباری)
# ═══════════════════════════════════════════════════════════════
# نحوه دریافت:
# 1. در تلگرام @BotFather را جستجو کنید
# 2. /newbot را ارسال کنید
# 3. نام و نام کاربری ربات را وارد کنید
# 4. توکن دریافتی را اینجا قرار دهید
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ═══════════════════════════════════════════════════════════════
# 🔥 Google Gemini API (کاملاً رایگان! - پیشنهادی)
# ═══════════════════════════════════════════════════════════════
# نحوه دریافت:
# 1. به https://aistudio.google.com بروید
# 2. با حساب گوگل لاگین کنید
# 3. روی "Get API Key" کلیک کنید
# 4. یک API Key جدید بسازید
# 5. کلید را در اینجا قرار دهید
GEMINI_API_KEY=your_gemini_api_key_here

# مدل Gemini (اختیاری)
# گزینه‌ها: gemini-1.5-flash (سریع و رایگان), gemini-1.5-pro (دقیق‌تر)
GEMINI_MODEL=gemini-1.5-flash

# ═══════════════════════════════════════════════════════════════
# 🤖 OpenAI API (هزینه‌بر - اختیاری)
# ═══════════════════════════════════════════════════════════════
# اگر AI_PROVIDER=openai تنظیم شده، این فیلدها را پر کنید
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ═══════════════════════════════════════════════════════════════
# 🔗 تنظیمات Webhook برای TradingView (اختیاری)
# ═══════════════════════════════════════════════════════════════

# فعال‌سازی سرور Webhook (true/false)
WEBHOOK_ENABLED=false

# کلید مخفی برای احراز هویت Alerts
# این کلید را در Alert TradingView هم استفاده کنید
WEBHOOK_SECRET=your_secure_secret_key_min_16_characters

# پورت سرور Webhook
WEBHOOK_PORT=8000

# ═══════════════════════════════════════════════════════════════
# ⚙️ تنظیمات عمومی
# ═══════════════════════════════════════════════════════════════

# سطح لاگینگ (INFO, DEBUG, WARNING, ERROR)
LOG_LEVEL=INFO

# فعال‌سازی دیتابیس (true/false)
DATABASE_ENABLED=false

# آدرس دیتابیس (برای PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/botdb

# ═══════════════════════════════════════════════════════════════
# 💡 مثال تنظیمات کامل برای استفاده رایگان:
# ═══════════════════════════════════════════════════════════════
# AI_PROVIDER=gemini
# TELEGRAM_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# GEMINI_API_KEY=AIzaSy....
# GEMINI_MODEL=gemini-1.5-flash
# WEBHOOK_ENABLED=true
# WEBHOOK_SECRET=my_secure_key_12345
# WEBHOOK_PORT=8000
# LOG_LEVEL=INFO
